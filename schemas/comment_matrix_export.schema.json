{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "title": "Comment Matrix Export",
  "description": "Deterministic export of review comments aligned to the Comment Resolution Engine comment-matrix contract.",
  "type": "object",
  "required": ["run_id", "generated_at", "format", "comments"],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Identifier linking to the review run manifest."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the export was produced."
    },
    "format": {
      "type": "string",
      "description": "Export format for the comment matrix contract. XLSX is the primary artifact; CSV is secondary.",
      "enum": ["comment-matrix", "comment-matrix-xlsx", "comment-matrix-csv"]
    },
    "comments": {
      "type": "array",
      "description": "Flattened comment records aligned to the Comment Resolution Engine spreadsheet columns.",
      "items": {
        "type": "object",
        "required": [
          "Comment Number",
          "Reviewer Initials",
          "Agency",
          "Report Version",
          "Section",
          "Page",
          "Line",
          "Agency Notes",
          "Agency Suggested Text Change",
          "WG Chain Comments",
          "NTIA Comments",
          "Comment Disposition",
          "Resolution",
          "Report Context",
          "Resolution Task",
          "Comment Cluster Id",
          "Intent Classification",
          "Section Group",
          "Heat Level",
          "Validation Status",
          "Validation Notes",
          "Resolved Against Revision",
          "Generation Mode",
          "Rule Id",
          "Rule Source",
          "Rule Version",
          "Rules Profile",
          "Rules Profile Version",
          "Matched Rule Types",
          "Review Status",
          "Confidence Score",
          "Provenance Record Id"
        ],
        "properties": {
          "Comment Number": { "type": ["string", "integer"] },
          "Reviewer Initials": { "type": "string" },
          "Agency": { "type": "string" },
          "Report Version": { "type": "string" },
          "Section": { "type": "string" },
          "Page": { "type": "string" },
          "Line": { "type": "string" },
          "Agency Notes": { "type": "string" },
          "Agency Suggested Text Change": { "type": "string" },
          "WG Chain Comments": { "type": "string" },
          "NTIA Comments": { "type": "string" },
          "Comment Disposition": { "type": "string" },
          "Resolution": { "type": "string" },
          "Report Context": { "type": "string" },
          "Resolution Task": { "type": "string" },
          "Comment Cluster Id": { "type": "string" },
          "Intent Classification": { "type": "string" },
          "Section Group": { "type": "string" },
          "Heat Level": { "type": "string" },
          "Validation Status": {
            "type": "string",
            "enum": ["NOT_VALIDATED", "VALIDATED", "REJECTED", "FLAGGED"]
          },
          "Validation Notes": { "type": "string" },
          "Resolved Against Revision": { "type": "string" },
          "Generation Mode": { "type": "string" },
          "Rule Id": { "type": "string" },
          "Rule Source": { "type": "string" },
          "Rule Version": { "type": "string" },
          "Rules Profile": { "type": "string" },
          "Rules Profile Version": { "type": "string" },
          "Matched Rule Types": { "type": "string" },
          "Review Status": { "type": "string" },
          "Confidence Score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "Provenance Record Id": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional export-level metadata (e.g., column order, delimiter settings).",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
